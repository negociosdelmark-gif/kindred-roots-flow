# ─────────────────────────────────────────────────────────────
# Variables de entorno — Dra. Eliana Angarita Julio
# Copia este archivo como ".env" y rellena con tus valores reales.
# NUNCA subas el ".env" real a GitHub (ya está protegido en .gitignore).
# En Vercel: configúralas en Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# --- Supabase (servidor / SSR) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_clave_publishable_aqui

# --- Supabase (cliente / navegador — prefijo VITE_) ---
VITE_SUPABASE_PROJECT_ID=tu_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=tu_clave_publishable_aqui
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
